# NotiChileC - Frontend (Expo) Environment Variables

# ============================================================
# API - Frontend Connection
# ============================================================
# URL de tu PC en la red local o backend publicado (para que el celular acceda)
# IMPORTANTE: Cambiá 192.168.0.4 por la IP de tu computadora
# Para finding tu IP: ipconfig (Windows) / ip a (Linux/macOS)
EXPO_PUBLIC_API_URL=http://192.168.0.4:3001

# ============================================================
# NOTE
# ============================================================
# Las variables privadas del backend viven en server/.env
