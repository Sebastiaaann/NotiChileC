# NotiChileC - Environment Variables

# ============================================================
# DATABASE
# ============================================================
# Connection string to PostgreSQL
# Format: postgres://username:password@host:port/database
# Example: postgres://postgres:password@localhost:5432/notichilec
DATABASE_URL=postgres://postgres:password@localhost:5432/notichilec

# ============================================================
# API - Frontend Connection
# ============================================================
# URL de tu PC en la red local (para que el celular acceda)
# IMPORTANTE: Cambiá 192.168.0.4 por la IP de tu computadora
# Para finding tu IP: ipconfig (Windows) / ip a (Linux/macOS)
EXPO_PUBLIC_API_URL=http://192.168.0.4:3000

# ============================================================
# PORT (Optional)
# ============================================================
PORT=3000