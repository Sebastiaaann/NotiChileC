{
  "name": "notichilec-server",
  "version": "1.0.0",
  "description": "Backend worker + API para NotiChileC",
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "dev:api": "tsx watch src/api.ts",
    "dev:worker": "tsx watch src/worker-entry.ts",
    "build": "tsc",
    "start": "node dist/server.js",
    "start:api": "node dist/api.js",
    "start:worker": "node dist/worker-entry.js",
    "worker:once": "tsx src/worker-entry.ts --once",
    "archive:export": "tsx scripts/archive-export.ts",
    "archive:restore": "tsx scripts/archive-restore.ts",
    "demo:seed": "tsx scripts/demo-seed.ts",
    "demo:reset": "tsx scripts/demo-reset.ts",
    "demo:smoke": "tsx scripts/demo-smoke.ts",
    "push:smoke": "tsx scripts/push-smoke.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "test-push": "tsx scripts/test-push.ts",
    "db:init": "psql $DATABASE_URL -f bootstrap.sql"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1022.0",
    "@sentry/node": "^10.47.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "expo-server-sdk": "^3.13.0",
    "express": "^4.21.2",
    "node-cron": "^3.0.3",
    "parquetjs-lite": "^0.8.7",
    "pg": "^8.13.1",
    "prom-client": "^15.1.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.10",
    "@types/supertest": "^7.2.0",
    "supertest": "^7.2.2",
    "tsx": "^4.19.2",
    "typescript": "~5.7.0",
    "vitest": "^4.1.2"
  },
  "private": true
}
