# NotiChileC - Backend Environment Variables
DATABASE_URL=postgresql://usuario:password@localhost:5432/notichilec
DATABASE_POOL_URL=postgresql://usuario:password@localhost:5432/notichilec
DATABASE_DIRECT_URL=postgresql://usuario:password@localhost:5432/notichilec
CHILECOMPRA_TICKET=tu-ticket-aqui
PORT=3001
WORKER_INTERVAL_MINUTES=5
DISPATCH_INTERVAL_MINUTES=1
RECEIPT_INTERVAL_MINUTES=1
CLEANUP_CRON=17 3 * * *
ARCHIVE_EXPORT_CRON=47 3 * * *
LOG_LEVEL=info
LOG_FORMAT=json
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_RELEASE=
DB_POOL_MAX=4
DB_IDLE_TIMEOUT_MS=30000
DB_CONNECTION_TIMEOUT_MS=5000
DB_READINESS_TIMEOUT_MS=1500
ARCHIVE_BUCKET=
ARCHIVE_PREFIX=notichilec/archive
ARCHIVE_REGION=us-east-1
ARCHIVE_ENDPOINT=
